{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    // composite は emit を止められないので、生成物はリポジトリ外(node_modules配下)へ捨てる。
    // vite.config.js がリポジトリに残ると、Vite が .ts より .js を優先して読んでしまう。
    "outDir": "./node_modules/.tmp/tsconfig-node"
  },
  "include": ["vite.config.ts"]
}
